# Spotify application client ID for the owner's app.
SPOTIFY_CLIENT_ID=your_client_id_here
# Spotify application client secret for the owner's app.
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# Spotify refresh token for the owner's account; spotify-auth.ts fills this locally.
SPOTIFY_REFRESH_TOKEN=
# HTTP port for the local Bun service behind nginx.
PORT=31890
# GitHub username whose latest public event should be exposed.
GITHUB_USER=joschi655
